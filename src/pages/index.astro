---
import Layout from "../layouts/Layout.astro";
import { client } from "../../tina/__generated__/client";

// Recupera tutti gli articoli dal CMS
const postsResponse = await client.queries.postConnection();
const posts =
	postsResponse.data.postConnection.edges?.map((edge) => edge.node) || [];

// Ordina gli articoli per data (dal più recente)
const sortedPosts = [...posts].sort((a, b) => {
	return new Date(b.date).getTime() - new Date(a.date).getTime();
});

// Format date in English
function formatDate(dateString: string) {
	const date = new Date(dateString);
	return date.toLocaleDateString("en-US", {
		day: "numeric",
		month: "long",
		year: "numeric",
	});
}
---

<Layout
	title="Nocturna — Chronicles from the Ether"
	description="A journey into mysticism, alchemy, and lunar cycles. Read our articles."
>
	<!-- Header Sottile ed Elegante -->
	<header
		class="border-b border-purple-950/30 bg-[#09070f]/80 backdrop-blur-md sticky top-0 z-50 transition-all duration-300"
	>
		<div
			class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between"
		>
			<a href="/" class="flex items-center gap-3 group">
				<!-- Icona Lunare SVG in Oro -->
				<svg
					class="w-6 h-6 text-[#d4af37] fill-current drop-shadow-[0_0_8px_rgba(212,175,55,0.6)] group-hover:rotate-12 transition-transform duration-500"
					viewBox="0 0 24 24"
					aria-hidden="true"
				>
					<path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"
					></path>
				</svg>
				<span
					class="font-cinzel text-xl font-bold tracking-[0.2em] text-[#f1ecf9] group-hover:text-purple-300 transition-colors duration-300"
				>
					NOCTURNA
				</span>
			</a>

			<nav
				class="hidden md:flex items-center gap-8 text-sm tracking-widest text-purple-300/60"
			>
				<a
					href="/"
					class="hover:text-[#d4af37] transition-colors duration-300 text-purple-200"
					>Chronicles</a
				>
				<a
					href="#about"
					class="hover:text-[#d4af37] transition-colors duration-300"
					>About</a
				>
				<a
					href="/admin/index.html"
					class="px-4 py-1.5 border border-purple-900/40 rounded-full hover:border-[#d4af37] hover:text-[#d4af37] transition-all duration-300 bg-purple-950/10"
				>
					Write
				</a>
			</nav>
		</div>
	</header>

	<main class="max-w-7xl mx-auto px-6 py-12 flex-grow">
		<!-- Sezione Hero -->
		<section
			class="text-center py-16 md:py-24 relative overflow-hidden rounded-3xl border border-purple-950/20 bg-gradient-to-b from-purple-950/5 to-transparent mb-16"
		>
			<!-- Bagliore decorativo della Hero -->
			<div
				class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(212,175,55,0.03)_0%,transparent_60%)] pointer-events-none"
			>
			</div>

			<div class="relative z-10 max-w-3xl mx-auto px-4 space-y-6">
				<div
					class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-purple-900/30 bg-purple-950/20 text-xs tracking-[0.2em] text-purple-300 uppercase"
				>
					<span>✨ Portal of Mystery</span>
				</div>
				<h1
					class="text-4xl md:text-6xl font-extrabold tracking-wide text-transparent bg-clip-text bg-gradient-to-r from-[#f1ecf9] via-[#e5def1] to-[#d4af37] leading-tight"
				>
					Chronicles from the Ether
				</h1>
				<p
					class="text-base md:text-lg text-purple-300/70 font-light leading-relaxed max-w-2xl mx-auto"
				>
					Explore the secrets of ancient wisdom, the magic of the
					stars, and the invisible influence of lunar cycles on our
					soul.
				</p>
			</div>
		</section>

		<!-- Griglia degli Articoli -->
		<section class="space-y-10">
			<h2
				class="text-2xl font-bold tracking-widest text-[#f1ecf9] border-b border-purple-950/40 pb-4 mb-8"
			>
				Latest Chronicles
			</h2>

			{
				sortedPosts.length === 0 ? (
					<div class="text-center py-16 border border-dashed border-purple-950/40 rounded-2xl bg-purple-950/5">
						<p class="text-purple-300/40 tracking-wider">
							No articles found in the grimoire.
						</p>
					</div>
				) : (
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
						{sortedPosts.map((post) => {
							const slug = post._sys.filename;
							const hasImage =
								post.image && post.image.trim() !== "";

							return (
								<article class="group flex flex-col border border-purple-950/60 bg-[#110d1a]/40 backdrop-blur-sm rounded-2xl overflow-hidden hover:border-[#d4af37]/40 hover:shadow-[0_0_30px_rgba(139,92,246,0.15)] hover:-translate-y-1.5 transition-all duration-500">
									<a
										href={`/blog/${slug}`}
										class="block flex-grow"
									>
										{/* Immagine o Geometria Sacra di Fallback */}
										<div class="relative aspect-[16/10] overflow-hidden bg-purple-950/20">
											{hasImage ? (
												<img
													src={post.image}
													alt={post.title}
													class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
													loading="lazy"
												/>
											) : (
												<div class="w-full h-full bg-gradient-to-br from-purple-950/40 to-[#0e0a16] flex items-center justify-center relative overflow-hidden group-hover:from-purple-900/40 transition-all duration-500">
													<svg
														class="w-16 h-16 text-purple-400/20 group-hover:text-[#d4af37]/30 group-hover:scale-110 transition-all duration-700"
														viewBox="0 0 100 100"
														fill="none"
														stroke="currentColor"
														stroke-width="1"
													>
														<circle
															cx="50"
															cy="50"
															r="40"
														/>
														<circle
															cx="50"
															cy="50"
															r="25"
														/>
														<circle
															cx="50"
															cy="50"
															r="10"
														/>
														<polygon points="50,10 90,50 50,90 10,50" />
														<polygon points="50,25 75,50 50,75 25,50" />
														<line
															x1="50"
															y1="10"
															x2="50"
															y2="90"
														/>
														<line
															x1="10"
															y1="50"
															x2="90"
															y2="50"
														/>
													</svg>
												</div>
											)}
											<div class="absolute inset-0 bg-gradient-to-t from-[#110d1a] to-transparent opacity-60" />
										</div>

										{/* Contenuto Card */}
										<div class="p-6 space-y-4">
											<div class="flex items-center gap-2 text-xs text-purple-400/60 font-medium tracking-wider">
												<span>
													{formatDate(post.date)}
												</span>
												{post.auraColor && (
													<>
														<span>•</span>
														<span class="capitalize text-[#d4af37]/80">
															{post.auraColor.replace(
																"-",
																" ",
															)}
														</span>
													</>
												)}
											</div>

											<h3 class="text-xl font-semibold tracking-wide text-[#f1ecf9] group-hover:text-[#d4af37] transition-colors duration-300 line-clamp-2">
												{post.title}
											</h3>

											<div class="text-sm text-purple-300/50 line-clamp-3 font-light leading-relaxed">
												{/* If there is a body text, we show a dummy hint of the post */}
												Click to delve into the reading
												and explore the revelations of
												this chapter.
											</div>
										</div>
									</a>
								</article>
							);
						})}
					</div>
				)
			}
		</section>
	</main>
</Layout>
